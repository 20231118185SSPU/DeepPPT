# ============================================================
#  Hermes Chrome - AI Agent Browser Configuration
#  Copy this file to .hermes-chrome.env and fill in your paths
# ============================================================

# Path to Chrome executable
# Windows default: C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS default:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux default:   /usr/bin/google-chrome
CHROME_EXE=

# Persistent profile directory (MUST be a non-default path)
# Chrome security policy requires --user-data-dir for CDP to work.
# This profile stores login sessions for ChatGPT / Grok / Perplexity etc.
# Examples:
#   Windows: C:\chrome-hermes-profile
#   macOS:   ~/chrome-hermes-profile
#   Linux:   ~/chrome-hermes-profile
HERMES_CHROME_PROFILE=

# CDP debugging port (default: 9222)
# browse_ai.py connects to this port for AI search automation
HERMES_CHROME_PORT=9222
